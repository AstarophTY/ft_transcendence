NODE_ENV=development
FRONTEND_URL=https://localhost
 
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=changeme
POSTGRES_DB=transcendence_db
DATABASE_URL=postgresql://transcendence:changeme@postgres:5432/transcendence_db
 
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@redis:6379
 
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
 
API_42_CLIENT_ID=your_42_client_id
API_42_CLIENT_SECRET=your_42_client_secret
API_42_REDIRECT_URI=https://localhost/api/auth/42/callback
 
VITE_API_URL=https://localhost/api
VITE_WS_URL=wss://localhost/ws
 
PUBLIC_API_KEY_SALT=change_this_salt
