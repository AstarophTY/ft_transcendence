/// A global building+voting season shared by every campus. At most one season
/// is *running* at a time, plus an optional *queued* next season scheduled to
/// start later (its world reset only fires once its build phase begins).
model Season {
  id            String    @id @default(uuid())
  title         String
  buildStartsAt DateTime
  buildEndsAt   DateTime
  voteStartsAt  DateTime
  voteEndsAt    DateTime
  finalizedAt   DateTime?
  startedAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  votes       SeasonVote[]
  results     SeasonResult[]
  campusVotes SeasonCampusVote[]
}

/// One ballot per voter per season. Voters and the islands they vote for share
/// the same campus.
model SeasonVote {
  id          String @id @default(uuid())
  seasonId    String
  campusId    String
  voterId     String
  candidateId String

  season    Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  campus    Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)
  voter     User   @relation("SeasonVoter", fields: [voterId], references: [id], onDelete: Cascade)
  candidate User   @relation("SeasonCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([seasonId, voterId])
  @@index([seasonId, campusId])
  @@index([candidateId])
}

/// One campus-level ballot per campus-less voter per season. Accounts without a
/// campus can't vote for an island, so they vote for the campus they think is
/// best instead — this drives the end-of-season campus podium.
model SeasonCampusVote {
  id       String @id @default(uuid())
  seasonId String
  voterId  String
  campusId String

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  voter  User   @relation("SeasonCampusVoter", fields: [voterId], references: [id], onDelete: Cascade)
  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One campus vote per user per season
  @@unique([seasonId, voterId])
  @@index([seasonId, campusId])
}

/// The winning island per campus for a finalized season.
model SeasonResult {
  id           String @id @default(uuid())
  seasonId     String
  campusId     String
  winnerUserId String?
  votes        Int    @default(0)

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@unique([seasonId, campusId])
}