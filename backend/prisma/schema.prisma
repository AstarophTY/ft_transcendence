generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(uuid())
  email         String? @unique
  username      String  @unique
  passwordHash  String?
  fortyTwoId    Int?    @unique
  fortyTwoLogin String?
  avatar        String?
  role          Role    @default(USER)
  isVerified    Boolean @default(false)

  displayName          String?
  bio                  String?
  campusId             String?
  campus               Campus?    @relation("CampusUsers", fields: [campusId], references: [id])
  coins                Int        @default(0)
  logtimeHours         Float      @default(0)
  monthLogtimeHours    Float      @default(0)
  fortyTwoAccessToken  String?
  fortyTwoRefreshToken String?
  language             String?
  theme                String?
  status               UserStatus @default(ONLINE)
  statusMessage        String?
  usernameChangedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  buildings        Building[]
  apiKeys          ApiKey[]

  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendAddressee")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  receiverId String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([requesterId])
}

model Building {
  id        String   @id @default(uuid())
  userId    String   @unique
  height    Float    @default(1.0)
  color     String   @default("#7F77DD")
  posX      Float    @default(0)
  posZ      Float    @default(0)
  campus    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campus])
}

model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique
  label      String
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campus {
  id    String @id @default(uuid())
  label String @unique
  /// Admin bonus added on top of the members' earned coins for the campus total.
  coins Int    @default(0)
  users User[] @relation("CampusUsers")
  world World?
}

/// The shared 3D world of a campus. The base terrain is regenerated on the fly
/// from this generation profile, so only the player edits are persisted (in
/// WorldBlock) on top of it.
model World {
  id       String @id @default(uuid())
  campusId String @unique
  campus   Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  /// Terrain generation profile (mirrors the frontend DemoPlanetProfile).
  seed           String
  widthInChunks  Int
  depthInChunks  Int
  scale          Float
  octaves        Int
  persistence    Float
  relief         Float
  baseHeight     Float
  variationRange Float

  blocks    WorldBlock[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model BlockLog {
  id     Int      @id @default(autoincrement())
  date   DateTime @default(now())
  userId String

  worldBlockWorldId String?
  worldBlockX       Int?
  worldBlockY       Int?
  worldBlockZ       Int?

  worldBlock WorldBlock? @relation(fields: [worldBlockWorldId, worldBlockX, worldBlockY, worldBlockZ], references: [worldId, x, y, z], onDelete: Cascade)

  @@index([userId])
  @@index([worldBlockWorldId, worldBlockX, worldBlockY, worldBlockZ])
}

/// A single block edited by a player, stored as a diff over the generated
/// terrain. A broken block is stored with `block = 0` (Air), so destroyed ground
/// is persisted too.
model WorldBlock {
  worldId   String
  world     World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  x         Int
  y         Int
  z         Int
  /// Block enum value (0 = Air for a broken block).
  block     Int
  block_log BlockLog[]
  /// Encoded block orientation (2 bits per X/Y/Z axis); 0 = unrotated.
  rotation  Int        @default(0)

  @@id([worldId, x, y, z])
  @@index([worldId])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ONLINE
  AWAY
  DND
  OFFLINE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}
