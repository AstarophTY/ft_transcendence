generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(uuid())
  email         String? @unique
  username      String  @unique
  passwordHash  String?
  fortyTwoId    Int?    @unique
  fortyTwoLogin String?
  avatar        String?
  role          Role    @default(USER)
  isVerified    Boolean @default(false)
  world         World?

  displayName          String?
  bio                  String?
  campusId             String?
  campus               Campus?    @relation("CampusUsers", fields: [campusId], references: [id])
  coins                Int        @default(0)
  /// Coins spent placing paid blocks; subtracted from the logtime-earned total.
  coinsSpent           Int        @default(0)
  logtimeHours         Float      @default(0)
  monthLogtimeHours    Float      @default(0)
  fortyTwoAccessToken  String?
  fortyTwoRefreshToken String?
  language             String?
  theme                String?
  /// Player avatar tint (hex color), shown on the 3D character.
  skinColor            String?
  status               UserStatus @default(ONLINE)
  statusMessage        String?
  usernameChangedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  buildings        Building[]
  apiKeys          ApiKey[]

  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendAddressee")

  seasonVotesCast     SeasonVote[] @relation("SeasonVoter")
  seasonVotesReceived SeasonVote[] @relation("SeasonCandidate")
  seasonCampusVotes   SeasonCampusVote[] @relation("SeasonCampusVoter")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  receiverId String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([requesterId])
}

model Building {
  id        String   @id @default(uuid())
  userId    String   @unique
  height    Float    @default(1.0)
  color     String   @default("#7F77DD")
  posX      Float    @default(0)
  posZ      Float    @default(0)
  campus    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campus])
}

model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique
  label      String
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campus {
  id String @id @default(uuid())

  label String @unique
  coins Int    @default(0)

  users User[] @relation("CampusUsers")

  world         World?
  seasonVotes   SeasonVote[]
  seasonResults SeasonResult[]
  seasonCampusVotes SeasonCampusVote[]
}

/// Lifecycle of the single global season. Phases are derived from the
/// timestamps below; admins "fast-forward" by setting a timestamp to now().
enum SeasonPhase {
  UPCOMING
  BUILD
  DELAY
  VOTE
  ENDED
}

/// A global building+voting season shared by every campus. At most one season
/// is *running* at a time, plus an optional *queued* next season scheduled to
/// start later (its world reset only fires once its build phase begins).
model Season {
  id            String    @id @default(uuid())
  title         String
  buildStartsAt DateTime
  buildEndsAt   DateTime
  /// When the vote opens (= buildEndsAt + configured delay).
  voteStartsAt  DateTime
  /// When the vote closes.
  voteEndsAt    DateTime
  /// Set once results are computed and winning islands copied to claim zones.
  finalizedAt   DateTime?
  /// When the season was activated (its world rollover ran). Null while it is
  /// still queued/scheduled — activation happens lazily at buildStartsAt.
  startedAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  votes       SeasonVote[]
  results     SeasonResult[]
  campusVotes SeasonCampusVote[]
}

/// One ballot per voter per season. Voters and the islands they vote for share
/// the same campus.
model SeasonVote {
  id          String @id @default(uuid())
  seasonId    String
  campusId    String
  voterId     String
  candidateId String

  season    Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  campus    Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)
  voter     User   @relation("SeasonVoter", fields: [voterId], references: [id], onDelete: Cascade)
  candidate User   @relation("SeasonCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One vote per user per season
  @@unique([seasonId, voterId])
  @@index([seasonId, campusId])
  @@index([candidateId])
}

/// One campus-level ballot per campus-less voter per season. Accounts without a
/// campus can't vote for an island, so they vote for the campus they think is
/// best instead — this drives the end-of-season campus podium.
model SeasonCampusVote {
  id       String @id @default(uuid())
  seasonId String
  voterId  String
  campusId String

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  voter  User   @relation("SeasonCampusVoter", fields: [voterId], references: [id], onDelete: Cascade)
  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One campus vote per user per season
  @@unique([seasonId, voterId])
  @@index([seasonId, campusId])
}

/// The winning island per campus for a finalized season.
model SeasonResult {
  id           String @id @default(uuid())
  seasonId     String
  campusId     String
  winnerUserId String?
  votes        Int    @default(0)

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@unique([seasonId, campusId])
}

model World {
  id String @id @default(uuid())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campusId String? @unique
  campus   Campus? @relation(fields: [campusId], references: [id], onDelete: Cascade)

  /// Terrain generation profile
  seed           String
  widthInChunks  Int
  depthInChunks  Int
  scale          Float
  octaves        Int
  persistence    Float
  relief         Float
  baseHeight     Float
  variationRange Float

  blocks    WorldBlock[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
  @@index([campusId])
}

model BlockLog {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  userId      String
  placedBlock Int      @default(0)

  worldBlockWorldId String?
  worldBlockX       Int?
  worldBlockY       Int?
  worldBlockZ       Int?

  worldBlock WorldBlock? @relation(fields: [worldBlockWorldId, worldBlockX, worldBlockY, worldBlockZ], references: [worldId, x, y, z], onDelete: Cascade)

  @@index([userId])
  @@index([worldBlockWorldId, worldBlockX, worldBlockY, worldBlockZ, placedBlock])
}

/// A single block edited by a player, stored as a diff over the generated
/// terrain. A broken block is stored with `block = 0` (Air), so destroyed ground
/// is persisted too.
model WorldBlock {
  worldId   String
  world     World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  x         Int
  y         Int
  z         Int
  /// Block enum value (0 = Air for a broken block).
  block     Int
  block_log BlockLog[]
  /// Encoded block orientation (2 bits per X/Y/Z axis); 0 = unrotated.
  rotation  Int        @default(0)

  @@id([worldId, x, y, z])
  @@index([worldId])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ONLINE
  AWAY
  DND
  OFFLINE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}
