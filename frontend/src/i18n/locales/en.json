  "legal": {
    "menuTitle": "Legal",
    "privacyTitle": "Privacy Policy",
    "termsTitle": "Terms of Service",
    "lastUpdated": "Last updated: June 2026",
    "privacyIntro": "This Privacy Policy explains what personal data ft_transcendence collects when you use the application, why we collect it, and the rights you have over it.",
    "privacySections": [
      {
        "title": "1. Data we collect",
        "body": "When you register we collect your username, email address and password (stored only as a salted hash, never in clear text). If you sign in with your 42 account, we receive your 42 login, email and profile picture. While you use the service we also store data you generate: your avatar, time spent connected (logtime), the blocks and contributions you place in the shared world, your friends list, messages, game results and your preferences (language and theme)."
      },
      {
        "title": "2. How we use your data",
        "body": "We use your data only to operate the service: to authenticate you, display your profile and presence to other players, save your world contributions and progress, manage your friendships and chat, and remember your settings. We do not sell your data or use it for advertising."
      },
      {
        "title": "3. Legal basis",
        "body": "We process your data to provide the service you signed up for and, where applicable, on the basis of your consent. You can withdraw consent at any time by deleting your account."
      },
      {
        "title": "4. Third parties",
        "body": "Authentication can be handled through the 42 OAuth service when you choose to log in with 42; in that case 42 processes your login according to its own privacy policy. We do not share your personal data with any other third party except where required by law."
      },
      {
        "title": "5. Data retention",
        "body": "We keep your data for as long as your account exists. When your account is deleted, your personal data (profile, email, credentials) is removed. Anonymised or aggregated data, and shared world contributions that cannot be linked back to you, may be retained."
      },
      {
        "title": "6. Your rights",
        "body": "You have the right to access, correct or delete your personal data, to object to or restrict its processing, and to request a copy of the data you provided. Most information can be updated from your profile settings."
      },
      {
        "title": "7. Security",
        "body": "Passwords are stored as salted hashes and access to the application is protected by authentication tokens served over an encrypted (HTTPS/WSS) connection. While no system can be guaranteed perfectly secure, we apply reasonable measures to protect your data."
      },
      {
        "title": "8. Cookies and local storage",
        "body": "We use your browser's local storage to keep you signed in and to remember preferences such as your chosen language. These are strictly necessary for the application to work and are not used for tracking or advertising."
      },
      {
        "title": "9. Changes and contact",
        "body": "We may update this Privacy Policy; the date above indicates the latest version. For any question about your personal data, contact the project administrators through the application."
      }
    ],
    "termsIntro": "These Terms of Service govern your use of ft_transcendence. By creating an account or using the application, you agree to these terms.",
    "termsSections": [
      {
        "title": "1. Acceptance of the terms",
        "body": "By accessing or using ft_transcendence you agree to be bound by these Terms of Service and by the Privacy Policy. If you do not agree, please do not use the application."
      },
      {
        "title": "2. Account & eligibility",
        "body": "ft_transcendence is an educational project intended for 42 students. You must provide accurate information when registering and you are responsible for keeping your credentials secure and for all activity under your account."
      },
      {
        "title": "3. Acceptable use",
        "body": "You agree not to misuse the service: no cheating or exploiting bugs, no harassment of other users, and no offensive, illegal or infringing content in usernames, chat messages, avatars or world contributions."
      },
      {
        "title": "4. User content",
        "body": "You remain responsible for the content you create (blocks, messages, avatar, profile). You grant the application the right to store and display this content as part of normal operation. We may moderate or remove content that breaches these terms."
      },
